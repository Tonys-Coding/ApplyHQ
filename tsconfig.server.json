{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "esnext",
    "lib": ["ESNext"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["bun"],
    // server/ imports a few pure modules out of src/ (shared domain types, the
    // term-preset regexes) and those files use the @/ alias internally, so the
    // server project has to resolve it too.
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "skipLibCheck": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["server", "scripts"]
}
