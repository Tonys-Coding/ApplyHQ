# ─────────────────────────────────────────────────────────────
# CLIENT — VITE_* vars are inlined into the browser bundle.
# Anything here is PUBLIC. Never add a secret to this section.
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# SERVER — read only by server/ (Bun). Never prefix these with
# VITE_, or they will be shipped to the client.
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
RAPIDAPI_KEY=
RAPIDAPI_HOST=jsearch.p.rapidapi.com
PORT=3001
